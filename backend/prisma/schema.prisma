// Prisma Schema для мессенджера
// PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ПОЛЬЗОВАТЕЛИ ============
model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  avatar    String?
  bio       String?
  status    String   @default("offline") // online, offline, away
  notificationSettings Json? // Заглушка: { emailNotifications, pushEnabled, etc. }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  messages           Message[]
  reactions          Reaction[]
  comments           Comment[]
  posts              Post[]
  userChats          UserChat[]
  createdChannels    Channel[] @relation("ChannelCreator")
  userPinnedMessages UserPinnedMessage[]
  channelMembers  ChannelMember[]
  postReactions   PostReaction[]
  postViews       PostView[]
  messageViews   MessageView[]
  stories        Story[]
  storyViews     StoryView[]
  stickerPacks   StickerPack[]
}

// ============ ЧАТЫ (личные и групповые) ============
model Chat {
  id        String   @id @default(uuid())
  isGroup   Boolean  @default(false)
  name      String?  // Для групповых чатов
  description String?  // Описание группы
  hideMembers Boolean  @default(false) // Скрывать список участников от не-админов
  avatar    String?  // Аватар группового чата
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages           Message[]
  userChats          UserChat[]
  pinnedMessages     ChatPinnedMessage[]
  userPinnedMessages UserPinnedMessage[]

  @@index([updatedAt])
}

// Закреплённые сообщения в чате для всех (ЛС: до 15, группы: до 30)
model ChatPinnedMessage {
  id        String   @id @default(uuid())
  chatId    String
  messageId String
  order     Int      @default(0)
  pinnedAt  DateTime @default(now())

  chat    Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([chatId, messageId])
  @@index([chatId])
  @@index([messageId])
}

// Закреплённые сообщения только для себя (видит только тот, кто закрепил)
model UserPinnedMessage {
  id        String   @id @default(uuid())
  userId    String
  chatId    String
  messageId String
  order     Int      @default(0)
  pinnedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat    Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, chatId, messageId])
  @@index([userId])
  @@index([chatId])
}

// Связь пользователей с чатами (участники)
model UserChat {
  id        String   @id @default(uuid())
  userId    String
  chatId    String
  role      String   @default("member") // member, admin
  joinedAt  DateTime @default(now())
  lastReadAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([userId, chatId])
  @@index([userId])
  @@index([chatId])
}

// ============ СООБЩЕНИЯ ============
model Message {
  id        String   @id @default(uuid())
  text      String
  isSystem  Boolean  @default(false) // системное уведомление (напр. "Пользователь X закрепил сообщение")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  editedAt  DateTime?
  isDeleted Boolean  @default(false)

  mediaUrls  String[] @default([]) // пути к медиафайлам (альбом)
  mediaTypes String[] @default([]) // 'image', 'video', 'document', 'sticker'

  isRead    Boolean  @default(false) // прочитано собеседником (для личных чатов)

  senderId String
  sender   User   @relation(fields: [senderId], references: [id], onDelete: Cascade)
  chatId   String
  chat     Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  replyToId     String?
  replyTo       Message?  @relation("Replies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies       Message[] @relation("Replies")
  forwardedFrom String?   // оригинальный отправитель при пересылке (например "username")

  reactions           Reaction[]
  views               MessageView[]
  pinnedInChats       ChatPinnedMessage[]
  pinnedByUsers        UserPinnedMessage[]

  @@index([chatId])
  @@index([senderId])
  @@index([createdAt])
}

// ============ КАНАЛЫ (публичные/приватные) ============
model Channel {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  hideMembers Boolean  @default(false) // Скрывать список подписчиков от не-админов
  avatar      String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creatorId   String
  creator     User    @relation("ChannelCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  posts       Post[]
  members     ChannelMember[]
  pinnedPosts ChannelPinnedPost[]

  @@index([slug])
  @@index([creatorId])
}

// Закреплённые посты в канале (до 50)
model ChannelPinnedPost {
  id        String   @id @default(uuid())
  channelId String
  postId    String
  order     Int      @default(0)
  pinnedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([channelId, postId])
  @@index([channelId])
  @@index([postId])
}

// Участники канала
model ChannelMember {
  id        String   @id @default(uuid())
  userId    String
  channelId String
  role      String   @default("member") // member, moderator, admin
  joinedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId])
  @@index([channelId])
}

// ============ ПОСТЫ В КАНАЛАХ ============
model Post {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  editedAt  DateTime?
  isDeleted Boolean  @default(false)

  mediaUrls  String[] @default([]) // пути к медиафайлам (альбом)
  mediaTypes String[] @default([]) // 'image', 'video', 'document'

  authorId  String
  author    User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  channelId     String
  channel       Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  viewCount     Int     @default(0)
  forwardedFrom String? // оригинальный отправитель при пересылке (например "username")

  comments       Comment[]
  reactions      PostReaction[]
  views          PostView[]
  pinnedInChannels ChannelPinnedPost[]

  @@index([channelId])
  @@index([authorId])
  @@index([createdAt])
}

// ============ УНИКАЛЬНЫЕ ПРОСМОТРЫ СООБЩЕНИЙ ============
model MessageView {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

// ============ РЕАКЦИИ НА СООБЩЕНИЯ ============
model Reaction {
  id        String   @id @default(uuid())
  emoji     String   // например: "👍", "❤️", "😂"
  createdAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId, emoji])
  @@index([messageId])
}

// ============ УНИКАЛЬНЫЕ ПРОСМОТРЫ ПОСТОВ ============
model PostView {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

// ============ РЕАКЦИИ НА ПОСТЫ ============
model PostReaction {
  id        String   @id @default(uuid())
  emoji     String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, emoji])
  @@index([postId])
}

// ============ КОММЕНТАРИИ К ПОСТАМ ============
model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  editedAt  DateTime?
  isDeleted Boolean  @default(false)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId   String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
}

// ============ СТИКЕРЫ ============
model StickerPack {
  id        String    @id @default(uuid())
  name      String
  iconUrl   String?   // URL первого стикера
  coverUrl  String?   // обложка пака
  authorId  String?   // null = старый/глобальный пак
  author    User?     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  stickers  Sticker[]
  createdAt DateTime  @default(now())

  @@index([authorId])
}

model Sticker {
  id     String      @id @default(uuid())
  url    String
  packId String
  pack   StickerPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([packId])
}

// ============ ИСТОРИИ (Stories) ============
model Story {
  id        String   @id @default(uuid())
  mediaUrl  String
  mediaType String   @default("image") // 'image' или 'video'
  caption   String?  @db.Text // текст подписи (оверлей)
  textSettings Json?  // { x, y, color } — координаты и цвет
  mediaSettings Json? // { stickers: [{ url, x, y }] } — стикеры поверх истории
  views     Int      @default(0)
  createdAt DateTime @default(now())
  expiresAt DateTime // createdAt + 24 часа

  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  storyViews StoryView[]

  @@index([authorId])
  @@index([expiresAt])
}

// ============ УНИКАЛЬНЫЕ ПРОСМОТРЫ ИСТОРИЙ ============
model StoryView {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([storyId])
  @@index([userId])
}
